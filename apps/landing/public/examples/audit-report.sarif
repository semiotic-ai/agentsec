{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "AgentSec",
          "version": "0.2.0",
          "informationUri": "https://agentsec.sh",
          "rules": [
            {
              "id": "AST03",
              "name": "Permissions",
              "shortDescription": {
                "text": "Network request with user-controlled URL"
              },
              "fullDescription": {
                "text": "Outbound network requests use a user-controlled URL. This is a Server-Side Request Forgery (SSRF) vulnerability that can access internal services."
              },
              "helpUri": "https://owasp.org/www-project-agentic-skills-top-10/",
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "excessive-permissions",
                  "security"
                ],
                "security-severity": "9.5"
              }
            },
            {
              "id": "AST-W01",
              "name": "Web3SigningAuthority",
              "shortDescription": {
                "text": "Hot signer has no per-call value cap"
              },
              "fullDescription": {
                "text": "The skill declares a hot signing key but does not set web3.policy.maxValuePerTx. A prompt-injected or hallucinated transaction can spend the full balance of the signer in a single call."
              },
              "helpUri": "https://github.com/markeljan/agentsec/blob/main/docs/plans/ast10-web3-annex-rules.md",
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "web3-signing-authority",
                  "security",
                  "web3",
                  "ast-web3-annex"
                ],
                "security-severity": "9.5"
              }
            },
            {
              "id": "AST-W12",
              "name": "Web3NoAuditKillswitch",
              "shortDescription": {
                "text": "Manifest declares web3 capabilities without an audit sink"
              },
              "fullDescription": {
                "text": "The skill's manifest exposes a `web3` block but does not declare `web3.audit.sink`. Without a tamper-evident audit trail recording which key signed which transaction under which policy on whose behalf, on-chain actions cannot be reconstructed during incident response."
              },
              "helpUri": "https://github.com/markeljan/agentsec/blob/main/docs/plans/ast10-web3-annex-rules.md",
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "web3-no-audit-killswitch",
                  "security",
                  "web3",
                  "ast-web3-annex"
                ],
                "security-severity": "7.5"
              }
            },
            {
              "id": "AST05",
              "name": "Storage",
              "shortDescription": {
                "text": "No .gitignore file found"
              },
              "fullDescription": {
                "text": "The skill has no .gitignore file. Without it, sensitive files (.env, credentials, private keys) may be committed to version control."
              },
              "helpUri": "https://owasp.org/www-project-agentic-skills-top-10/",
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "tags": [
                  "insecure-storage",
                  "security"
                ],
                "security-severity": "5.0"
              }
            },
            {
              "id": "AST08",
              "name": "Logging",
              "shortDescription": {
                "text": "No logging found in skill"
              },
              "fullDescription": {
                "text": "The skill has no logging statements across any files. Without logging, it is impossible to audit the skill's behavior, detect anomalies, or investigate security incidents."
              },
              "helpUri": "https://owasp.org/www-project-agentic-skills-top-10/",
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "tags": [
                  "insufficient-logging",
                  "security"
                ],
                "security-severity": "5.0"
              }
            },
            {
              "id": "AST-W05",
              "name": "Web3RpcSubstitution",
              "shortDescription": {
                "text": "RPC URL from environment without chainId integrity check"
              },
              "fullDescription": {
                "text": "The skill reads its RPC URL from `process.env` but does not cross-check the resolved network via `eth_chainId` / `getChainId` / `getNetwork`. An attacker who controls the env (malicious MCP config, supply-chain pin replacement, container hijack) can silently redirect the skill to a hostile chain."
              },
              "helpUri": "https://github.com/markeljan/agentsec/blob/main/docs/plans/ast10-web3-annex-rules.md",
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "tags": [
                  "web3-rpc-substitution",
                  "security",
                  "web3",
                  "ast-web3-annex"
                ],
                "security-severity": "5.0"
              }
            },
            {
              "id": "AST-W06",
              "name": "Web3ContractTargets",
              "shortDescription": {
                "text": "ENS forward-resolution without reverse-resolution"
              },
              "fullDescription": {
                "text": "The skill resolves an ENS name to an address but never reverse-resolves to confirm the address still maps back to that name. Dangling ENS records or attacker-controlled subdomains can swap the resolved address out from under the agent."
              },
              "helpUri": "https://github.com/markeljan/agentsec/blob/main/docs/plans/ast10-web3-annex-rules.md",
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "tags": [
                  "web3-contract-targets",
                  "security",
                  "web3",
                  "ast-web3-annex"
                ],
                "security-severity": "5.0"
              }
            },
            {
              "id": "AST06",
              "name": "Dos",
              "shortDescription": {
                "text": "Network request detected (check for timeout)"
              },
              "fullDescription": {
                "text": "Network requests without timeouts can hang indefinitely if the remote server is slow or unresponsive, effectively creating a denial of service."
              },
              "helpUri": "https://owasp.org/www-project-agentic-skills-top-10/",
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "tags": [
                  "denial-of-service",
                  "security"
                ],
                "security-severity": "2.5"
              }
            },
            {
              "id": "AST-W11",
              "name": "Web3KeyMaterialLeak",
              "shortDescription": {
                "text": "Private-key constant declared inline"
              },
              "fullDescription": {
                "text": "A 64-character hex value is bound to a constant whose name suggests key material (PRIVATE_KEY, SECRET, MNEMONIC). Keys that live in source are leaked the moment the file is committed, copied to a sandbox, or shipped in a build artifact."
              },
              "helpUri": "https://github.com/markeljan/agentsec/blob/main/docs/plans/ast10-web3-annex-rules.md",
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "web3-key-material-leak",
                  "security",
                  "web3",
                  "ast-web3-annex"
                ],
                "security-severity": "9.5"
              }
            },
            {
              "id": "AST-W07",
              "name": "Web3BridgeReplay",
              "shortDescription": {
                "text": "Multi-chain skill missing bridgeProvider declaration"
              },
              "fullDescription": {
                "text": "The manifest declares two or more chains in web3.chains but does not name a bridgeProvider. Operators cannot tell which bridge the skill will use, which prevents allowlisting a specific endpoint and enables silent bridge swapping at runtime."
              },
              "helpUri": "https://github.com/markeljan/agentsec/blob/main/docs/plans/ast10-web3-annex-rules.md",
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "web3-bridge-replay",
                  "security",
                  "web3",
                  "ast-web3-annex"
                ],
                "security-severity": "7.5"
              }
            },
            {
              "id": "AST-W08",
              "name": "Web3McpChainDrift",
              "shortDescription": {
                "text": "MCP server declared without pinnedHash or pinnedVersion"
              },
              "fullDescription": {
                "text": "The MCP server entry at index 0 (`https://example.com/mcp`) is declared without a `pinnedHash` or `pinnedVersion`. The upstream server can be silently updated to add new chain tools, expand parameter schemas, or rebind the same tool name to a different RPC / contract — turning a previously-audited capability surface into an attacker-controlled one."
              },
              "helpUri": "https://github.com/markeljan/agentsec/blob/main/docs/plans/ast10-web3-annex-rules.md",
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "web3-mcp-chain-drift",
                  "security",
                  "web3",
                  "ast-web3-annex"
                ],
                "security-severity": "7.5"
              }
            },
            {
              "id": "AST-W09",
              "name": "Web3SessionKeyErosion",
              "shortDescription": {
                "text": "requestPermissions call without nearby expiry"
              },
              "fullDescription": {
                "text": "Code calls `requestPermissions` / `wallet_requestPermissions` but no `expiry` or `expiration` token appears within ~500 characters of the call. Permissions requested without a stated lifetime are usually persistent — the wallet treats them as long-lived."
              },
              "helpUri": "https://github.com/markeljan/agentsec/blob/main/docs/plans/ast10-web3-annex-rules.md",
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "web3-session-key-erosion",
                  "security",
                  "web3",
                  "ast-web3-annex"
                ],
                "security-severity": "7.5"
              }
            },
            {
              "id": "AST01",
              "name": "Injection",
              "shortDescription": {
                "text": "Untrusted variable interpolation in template"
              },
              "fullDescription": {
                "text": "User-controlled variables are interpolated into template literals without sanitization. This can allow prompt injection or command injection depending on context."
              },
              "helpUri": "https://owasp.org/www-project-agentic-skills-top-10/",
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "skill-injection",
                  "security"
                ],
                "security-severity": "7.5"
              }
            },
            {
              "id": "AST-W10",
              "name": "Web3OracleManipulation",
              "shortDescription": {
                "text": "Slippage tolerance exceeds 5%"
              },
              "fullDescription": {
                "text": "A static slippage value of 10 is configured, which is larger than the 5% safety threshold. Wide slippage tolerances let a manipulated pool drain a meaningful fraction of every trade."
              },
              "helpUri": "https://github.com/markeljan/agentsec/blob/main/docs/plans/ast10-web3-annex-rules.md",
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "web3-oracle-manipulation",
                  "security",
                  "web3",
                  "ast-web3-annex"
                ],
                "security-severity": "7.5"
              }
            },
            {
              "id": "AST-W03",
              "name": "Web3Eip7702Delegation",
              "shortDescription": {
                "text": "EIP-7702 signing declared without delegate allowlist or expiry"
              },
              "fullDescription": {
                "text": "The skill declares web3.signs7702 = true but provides neither web3.policy.allowedContracts nor web3.policy.expiry. A 7702 SetCodeAuthorization without scoped delegate targets and a time bound can install attacker-controlled code on the EOA and silently drain tokens, NFTs, and approvals."
              },
              "helpUri": "https://github.com/markeljan/agentsec/blob/main/docs/plans/ast10-web3-annex-rules.md",
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "web3-eip7702-delegation",
                  "security",
                  "web3",
                  "ast-web3-annex"
                ],
                "security-severity": "9.5"
              }
            },
            {
              "id": "AST02",
              "name": "SupplyChain",
              "shortDescription": {
                "text": "Remote code execution via pipe to shell"
              },
              "fullDescription": {
                "text": "Code is downloaded from a URL and piped directly to a shell interpreter without integrity verification. This is the most dangerous supply chain pattern."
              },
              "helpUri": "https://owasp.org/www-project-agentic-skills-top-10/",
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "supply-chain",
                  "security"
                ],
                "security-severity": "9.5"
              }
            },
            {
              "id": "AST-W02",
              "name": "Web3PermitCapture",
              "shortDescription": {
                "text": "Permit2 EIP-712 signature flow without spender allowlist"
              },
              "fullDescription": {
                "text": "This file references the canonical Permit2 contract address and triggers an EIP-712 signTypedData prompt, but no recognized Permit2 spender (e.g., Uniswap UniversalRouter, 0x Settler) appears in the same file. A malicious skill can frame the signature as a benign approval while the underlying PermitSingle/PermitBatch grants an attacker-controlled spender unbounded allowance over the user's tokens."
              },
              "helpUri": "https://github.com/markeljan/agentsec/blob/main/docs/plans/ast10-web3-annex-rules.md",
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "web3-permit-capture",
                  "security",
                  "web3",
                  "ast-web3-annex"
                ],
                "security-severity": "9.5"
              }
            },
            {
              "id": "AST04",
              "name": "OutputHandling",
              "shortDescription": {
                "text": "Dynamic file path in write operation"
              },
              "fullDescription": {
                "text": "File write operations with dynamically constructed paths are vulnerable to path traversal. An attacker could write to arbitrary locations using '../' sequences."
              },
              "helpUri": "https://owasp.org/www-project-agentic-skills-top-10/",
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "insecure-output",
                  "security"
                ],
                "security-severity": "7.5"
              }
            },
            {
              "id": "AST-W04",
              "name": "Web3BlindSigning",
              "shortDescription": {
                "text": "personal_sign exposed — prefer signTypedData_v4"
              },
              "fullDescription": {
                "text": "The skill calls personal_sign / eth_sign, which produces an opaque signature over a raw byte string. Users cannot verify what they are signing, and the signature can be replayed in any context. Use signTypedData_v4 with a structured domain so wallets render typed fields."
              },
              "helpUri": "https://github.com/markeljan/agentsec/blob/main/docs/plans/ast10-web3-annex-rules.md",
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "web3-blind-signing",
                  "security",
                  "web3",
                  "ast-web3-annex"
                ],
                "security-severity": "7.5"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "permissions",
