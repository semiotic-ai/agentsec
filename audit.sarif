{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Agent Audit",
          "version": "0.1.0",
          "informationUri": "https://github.com/agent-audit/agent-audit",
          "rules": [
            {
              "id": "injection",
              "name": "Injection",
              "shortDescription": {
                "text": "Use of eval() detected"
              },
              "fullDescription": {
                "text": "eval() executes arbitrary code at runtime and is a primary injection vector. An attacker can craft input that escapes the intended context and executes arbitrary commands."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "skill-injection",
                  "security"
                ],
                "security-severity": "9.5"
              }
            },
            {
              "id": "supply-chain",
              "name": "SupplyChain",
              "shortDescription": {
                "text": "Remote code execution via pipe to shell"
              },
              "fullDescription": {
                "text": "Code is downloaded from a URL and piped directly to a shell interpreter without integrity verification. This is the most dangerous supply chain pattern."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "supply-chain",
                  "security"
                ],
                "security-severity": "9.5"
              }
            },
            {
              "id": "storage",
              "name": "Storage",
              "shortDescription": {
                "text": "Weak hash algorithm used"
              },
              "fullDescription": {
                "text": "MD5 or SHA1 are used for hashing. These algorithms have known collision attacks and should not be used for security-sensitive operations."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "insecure-storage",
                  "security"
                ],
                "security-severity": "7.5"
              }
            },
            {
              "id": "permissions",
              "name": "Permissions",
              "shortDescription": {
                "text": "Network request detected"
              },
              "fullDescription": {
                "text": "The skill makes outbound network requests. Without URL validation, this could enable SSRF (Server-Side Request Forgery) or data exfiltration."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "tags": [
                  "excessive-permissions",
                  "security"
                ],
                "security-severity": "5.0"
              }
            },
            {
              "id": "logging",
              "name": "Logging",
              "shortDescription": {
                "text": "No logging found in skill"
              },
              "fullDescription": {
                "text": "The skill has no logging statements across any files. Without logging, it is impossible to audit the skill's behavior, detect anomalies, or investigate security incidents."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "tags": [
                  "insufficient-logging",
                  "security"
                ],
                "security-severity": "5.0"
              }
            },
            {
              "id": "dos",
              "name": "Dos",
              "shortDescription": {
                "text": "Network request detected (check for timeout)"
              },
              "fullDescription": {
                "text": "Network requests without timeouts can hang indefinitely if the remote server is slow or unresponsive, effectively creating a denial of service."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "tags": [
                  "denial-of-service",
                  "security"
                ],
                "security-severity": "2.5"
              }
            },
            {
              "id": "deserialization",
              "name": "Deserialization",
              "shortDescription": {
                "text": "Node.js VM module used for deserialization"
              },
              "fullDescription": {
                "text": "The Node.js vm module is used to execute serialized code. The vm module is not a security boundary and can be escaped."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "unsafe-deserialization",
                  "security"
                ],
                "security-severity": "9.5"
              }
            },
            {
              "id": "output-handling",
              "name": "OutputHandling",
              "shortDescription": {
                "text": "Dynamic file path in write operation"
              },
              "fullDescription": {
                "text": "File write operations with dynamically constructed paths are vulnerable to path traversal. An attacker could write to arbitrary locations using '../' sequences."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "insecure-output",
                  "security"
                ],
                "security-severity": "7.5"
              }
            }
          ]
        }
      },
