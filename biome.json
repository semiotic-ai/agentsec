{
  "$schema": "node_modules/@biomejs/biome/configuration_schema.json",
  "assist": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn",
        "noAssignInExpressions": "warn",
        "noTemplateCurlyInString": "warn",
        "noControlCharactersInRegex": "off",
        "noArrayIndexKey": "warn",
        "noUnknownAtRules": "off"
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": {
            "maxAllowedComplexity": 50
          }
        },
        "noUselessEscapeInRegex": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "files": {
    "includes": [
      "**",
      "!node_modules",
      "!**/dist",
      "!**/.next",
      "!.turbo",
      "!coverage",
      "!.reference",
      "!.claude",
      "!e2e/fixtures",
      "!examples"
    ]
  }
}
