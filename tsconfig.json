{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["@types/bun"],
    "paths": {
      "@agentsec/*": ["./packages/*/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
