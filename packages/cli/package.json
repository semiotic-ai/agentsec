{
  "name": "agent-audit",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "bin": {
    "agent-audit": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target bun",
    "dev": "bun build src/cli.ts --outdir dist --target bun --watch",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agent-audit/shared": "workspace:*",
    "@agent-audit/scanner": "workspace:*",
    "@agent-audit/openclaw": "workspace:*",
    "@agent-audit/metrics": "workspace:*",
    "@agent-audit/policy": "workspace:*",
    "@agent-audit/reporter": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^6.0.2"
  }
}
