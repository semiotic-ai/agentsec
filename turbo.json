{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },
    "//#lint": {
      "inputs": [
        "biome.json",
        "packages/**/*.ts",
        "packages/**/*.json",
        "apps/**/*.ts",
        "apps/**/*.json",
        "e2e/**/*.ts"
      ]
    },
    "//#check": {
      "dependsOn": ["build"]
    },
    "//#format": {
      "inputs": [
        "biome.json",
        "packages/**/*.ts",
        "packages/**/*.json",
        "apps/**/*.ts",
        "apps/**/*.json",
        "e2e/**/*.ts"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}
