{
  "name": "agentsec",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "bunx biome check .",
    "format": "bunx biome check --write .",
    "check": "tsc --project tsconfig.check.json",
    "audit": "bun packages/cli/src/cli.ts audit",
    "demo": "bun packages/cli/src/cli.ts audit --path ./e2e/fixtures",
    "clean": "turbo clean",
    "bump": "bun run scripts/bump-version.ts",
    "check:versions": "bun run scripts/check-versions.ts",
    "compare:web3": "bun run scripts/run-web3-comparison.ts",
    "publish:clawhub": "bunx clawhub@latest publish skills/agentsec --slug agentsec --owner markeljan --version $(jq -r .version packages/cli/package.json)"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.11"
}
