{
  "name": "agent-audit",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "check": "turbo check",
    "audit": "bun run --filter @agent-audit/cli -- audit",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.11"
}
