{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["bun-types"],
    "paths": {
      "@agent-audit/*": ["../packages/*/src"]
    }
  },
  "include": ["*.ts", "fixtures/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
