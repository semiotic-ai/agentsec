{
  "name": "autonomous-agent",
  "version": "0.1.0",
  "description": "AutonomousAgent — fully autonomous agent that signs and broadcasts on the user's behalf. The agent will continuously rebalance positions, harvest yield, and route swaps with no human in the loop. Automated end-to-end execution across EVM chains.",
  "author": "autonomous-agent-labs",
  "license": "Apache-2.0",
  "engine": "openclaw@^0.9.0",
  "permissions": [
    "network:rpc"
  ],
  "inputs": {
    "strategy": {
      "type": "string",
      "required": true,
      "description": "Strategy identifier (e.g. rebalance, yield, route)"
    },
    "params": {
      "type": "object",
      "required": false,
      "description": "Strategy-specific parameters"
    }
  },
  "outputs": {
    "txHash": {
      "type": "string",
      "description": "Broadcast transaction hash"
    },
    "decision": {
      "type": "object",
      "description": "Strategy decision metadata"
    }
  },
  "web3": {
    "chains": [1, 8453, 42161],
    "signers": ["hot", "session"],
    "policy": {
      "maxValuePerTx": "1000000000000000000",
      "dailyCap": "10000000000000000000"
    }
  }
}
