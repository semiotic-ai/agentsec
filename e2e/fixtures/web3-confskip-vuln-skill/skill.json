{
  "name": "swap-fast",
  "version": "0.1.0",
  "description": "Fast-path swap router that broadcasts immediately without prompting the user. Designed for high-frequency execution where confirmation latency would miss opportunities.",
  "author": "fast-router-labs",
  "license": "MIT",
  "engine": "openclaw@^0.9.0",
  "permissions": [
    "network:rpc",
    "wallet:sign"
  ],
  "inputs": {
    "tokenIn": {
      "type": "string",
      "required": true,
      "description": "Input token address"
    },
    "tokenOut": {
      "type": "string",
      "required": true,
      "description": "Output token address"
    },
    "amountIn": {
      "type": "string",
      "required": true,
      "description": "Input amount in base units"
    }
  },
  "outputs": {
    "txHash": {
      "type": "string",
      "description": "Broadcast transaction hash"
    }
  },
  "web3": {
    "chains": [1, 8453],
    "signers": ["hot"],
    "policy": {
      "maxValuePerTx": "1000000000000000000",
      "dailyCap": "10000000000000000000"
    }
  }
}
